<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo2.controller.SudokuController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
   <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;" text="Sudoku" />

    <GridPane fx:id="sudokuGrid" alignment="CENTER" prefHeight="380.0" prefWidth="380.0" style="-fx-background-color: #16213e; -fx-padding: 10; -fx-background-radius: 8;" />
    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="helpButton" onAction="#onHandleHelp" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" text="💡 Ayuda">Help</Button>
        <Button fx:id="newGameButton" onAction="#onHandleNewGame" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" text="🔄 Nueva Partida">New Game</Button>
    </HBox>

</VBox>
