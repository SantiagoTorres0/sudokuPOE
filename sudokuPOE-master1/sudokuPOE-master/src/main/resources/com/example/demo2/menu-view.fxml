<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="500.0" spacing="30.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo2.controller.MenuController">

    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <Label fx:id="titleLabel" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;" text="Sudoku" />
    <Button fx:id="startButton" onAction="#onHandleStart" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25;" text="Start" />

</VBox>
